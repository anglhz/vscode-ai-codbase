PORT=3000
HOST=127.0.0.1
NODE_ENV=development

# Change these before hosting.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_SESSION_TTL_MS=43200000

# CoD1 UDP server status queries
COD_QUERY_TIMEOUT_MS=900
SERVER_STATUS_CACHE_MS=15000

# TeamSpeak 3 ServerQuery. Voice ports are still entered in admin.
TS3_QUERY_PORT=10011
TS3_QUERY_TIMEOUT_MS=1500

# Discord news sync, used by: npm run discord:sync
DISCORD_BOT_TOKEN=
DISCORD_NEWS_CHANNEL_ID=
DISCORD_SYNC_INTERVAL_MS=60000
